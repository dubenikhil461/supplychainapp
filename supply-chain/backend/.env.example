# filename: backend/.env.example
# purpose: Environment variables required by backend services.
# setup notes: Copy to backend/.env and set a real Anthropic API key.
# Default 5001 avoids macOS AirPlay/Control Center on 5000; must match frontend/vite.config.js proxy.
PORT=5003
ANTHROPIC_API_KEY=your_key_here
# Fraud analysis (fraudRoutes.js). If requests fail with "fetch failed", check network/VPN and try: NODE_OPTIONS='--dns-result-order=ipv4first' node index.js
GEMINI_API_KEY=your_key_here
